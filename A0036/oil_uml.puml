@startuml oil_sequence_delete

title oil_delete_data.py - データ削除処理 シーケンス図

actor User
participant "oil_delete_data" as Script
participant "Common_data\n(oil_common_data)" as Common
participant "Excel\n(月別石油価格推移データ.xlsx)" as Excel

User -> Script : スクリプト実行
Script -> Common : Common_data() インスタンス生成
Common -> Excel : load_workbook() で開く

Script -> Common : data_clear() 呼び出し

loop row in range(1, 6) → 行1〜5
    loop col in range(1, 26) → 列1〜25
        Common -> Excel : ws.cell(row, col).value = ""
    end
end

Common -> Excel : wb.save()
Common -> Excel : wb.close()
Script --> User : 処理完了

@enduml
